# ===== Application =====
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ===== Database =====
DATABASE_URL=postgresql://postgres:change_this_password_in_dev@localhost:5432/aniston_vms?schema=public

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== Encryption (AES-256-GCM) =====
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-byte-hex-key-64-chars-exactly

# ===== Email (Nodemailer SMTP) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Aniston VMS <noreply@example.com>"

# ===== Storage =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ===== Media / Playback (MediaMTX) =====
# Internal, server-side only (backend → MediaMTX control plane + edge relay). In
# production these MUST point at the private media tier / edge relay, NOT
# localhost, and MUST NOT be reachable from the public internet.
# MEDIAMTX_API_URL=http://mediamtx:9997
# MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554
# MEDIAMTX_WEBRTC_URL=http://mediamtx:8889
# MEDIAMTX_HLS_URL=http://mediamtx:8888
# Browser-facing playback. Same-origin by default ('' → inherits the page's
# HTTPS/WSS, served via nginx /media/* with auth_request). Set to an absolute
# https:// origin only if media is served from a different host.
MEDIA_PUBLIC_BASE_URL=
# REQUIRED in production — HMAC key that signs short-lived browser media URLs.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MEDIA_URL_SIGNING_SECRET=
# Lifetime (seconds) of a signed playback URL (30-3600). Default 300.
# PLAYBACK_URL_TTL_SECONDS=300

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=50

# ===== Health Engine =====
# NOTE: boolean flags are coerced with Boolean(value) — any non-empty value
# (even "false") counts as true. Leave them commented out to keep defaults.
# HEALTH_SCHEDULER_ENABLED=true   # default: true
# HEALTH_SIM_MODE=true            # default: false; fakes probes for demo/dev
# HEALTH_CHECK_INTERVAL_MINUTES=5
# HEALTH_CAMS_PER_MINUTE=25
# HEALTH_TCP_TIMEOUT_MS=4000
# HEALTH_FFPROBE_TIMEOUT_MS=15000
# HEALTH_RETRY_DELAY_MS=5000

# ===== Logging =====
LOG_LEVEL=info

# ===== Production-only flags =====
ALLOW_PROD_SEED=false
