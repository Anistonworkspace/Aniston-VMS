// Aniston VMS — Prisma schema
// Implements docs/05-backend-schema.md (Doc version: v1.0 · 17 July 2026 · Built for plan v1.3)
// PostgreSQL 16 · All tables: id uuid pk, created_at, updated_at unless noted · Timestamps UTC.
// Conventions (.claude/rules/rule-naming-conventions.md): PascalCase singular models,
// camelCase fields mapped to snake_case columns, snake_case plural table names via @@map.
// Every enum here is mirrored in shared/src/enums.ts — keep them in sync.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (docs/05-backend-schema.md §Enums)
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PROJECT_ADMIN
  OPERATOR
  ENGINEER
  CLIENT_VIEWER
  AUDITOR
}

enum ScopeType {
  ALL
  REGION
  ZONE
  SITE
  CAMERA
}

enum PermissionType {
  LIVE_VIEW
}

enum CameraStatus {
  HEALTHY
  WARNING
  CRITICAL
  MAINTENANCE
  UNKNOWN
}

// Provisioning lifecycle — deliberately SEPARATE from health `status` (which is
// an observed runtime signal). This tracks how far a physical camera has moved
// through commissioning:
//   DRAFT      = registered in inventory with identity only (code/name/brand).
//                Not placed, not wired to a stream, never streamable, excluded
//                from the health probe cycle and the Live Wall.
//   CONFIGURED = placement + network + RTSP config saved AND a real connection
//                test has passed. Only CONFIGURED cameras are streamable / probed.
// Transitions are admin/engineer-gated (see camera.provisioning.ts state machine):
//   DRAFT → CONFIGURED requires a passing server-side probe; CONFIGURED → DRAFT
//   is an admin-only deactivation.
enum CameraProvisioning {
  DRAFT
  CONFIGURED
}

enum Diagnosis {
  SITE_INTERNET_DOWN
  SIM_SIGNAL_ISSUE
  NETWORK_UNSTABLE
  CAMERA_OFFLINE
  CONFIG_ERROR
  STREAM_DEGRADED
  IMAGE_PROBLEM
  WATERLOGGING // placeholder, unused in v1.5 — Phase-2 waterlogging roadmap
}

enum CheckType {
  ROUTER_TCP
  RTSP_PORT
  RTSP_AUTH
  VIDEO_VALIDATION
  SNAPSHOT
  IMAGE_ANALYSIS
  SD_HEALTH
}

enum IncidentStatus {
  DETECTED
  CONFIRMED
  ALERTED
  ACKNOWLEDGED
  ASSIGNED
  INVESTIGATING
  RESOLVED
  RECOVERY_VERIFIED
  CLOSED
}

enum Severity {
  INFO
  WARNING
  CRITICAL
}

enum Channel {
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  ACCEPTED
  SENT
  DELIVERED
  READ
  BOUNCED
  FAILED
}

enum StreamKind {
  LIVE_SUB
  LIVE_MAIN
  PLAYBACK
}

enum PlaybackAdapter {
  ONVIF_G
  HIKVISION
  DAHUA
  NONE
}

enum ClipStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum TaskType {
  LENS_CLEANING
  REPAIR
  INSPECTION
}

enum TaskSource {
  AUTO
  MANUAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum LayoutKind {
  L1x1
  L2x2
  L3x2
}

// Inline value sets from the doc: snapshots.kind (SUB|EVIDENCE),
// recording_segments.track (MAIN|SUB) — modelled as enums for type safety.

enum SnapshotKind {
  SUB
  EVIDENCE
}

enum RecordingTrack {
  MAIN
  SUB
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & access
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  phone        String
  role         Role
  mfaSecret    String?   @map("mfa_secret")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  accessScopes               UserAccessScope[]
  refreshTokens              RefreshToken[]
  auditLogs                  AuditLog[]
  approvedReferenceImages    ReferenceImage[]
  assignedIncidents          Incident[]            @relation("IncidentAssignedTo")
  approvedMaintenanceWindows MaintenanceWindow[]
  assignedMaintenanceTasks   MaintenanceTask[]     @relation("MaintenanceTaskAssignedTo")
  streamSessions             StreamSession[]
  clipExports                ClipExport[]
  savedLayouts               SavedLayout[]
  permissions                UserPermission[]      @relation("UserPermissionUser")
  grantedPermissions         UserPermission[]      @relation("UserPermissionGrantedBy")
  backups                    Backup[]
  incidentReadReceipts       IncidentReadReceipt[] @relation("UserIncidentReadReceipts")

  @@map("users")
}

model UserAccessScope {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  scopeType ScopeType @map("scope_type")
  scopeId   String?   @map("scope_id") // null when ALL
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("user_access_scopes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String   @map("ip_address")
  siteId     String?  @map("site_id")
  zoneId     String?  @map("zone_id")
  createdAt  DateTime @default(now()) @map("created_at") // append-only: no updated_at

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([siteId])
  @@index([zoneId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Hierarchy & devices  (Region → Zone → Site → Camera)
// ─────────────────────────────────────────────────────────────────────────────

model Region {
  id        String   @id @default(uuid())
  name      String   @unique // "North"…
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones Zone[]

  @@map("regions")
}

model Zone {
  id        String   @id @default(uuid())
  regionId  String   @map("region_id")
  name      String
  latitude  Float?
  longitude Float?
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  region             Region               @relation(fields: [regionId], references: [id])
  sites              Site[]
  incidents          Incident[]
  escalationPolicies EscalationPolicy[]
  alertRecipients    ZoneAlertRecipient[]

  @@unique([regionId, name])
  @@map("zones")
}

model Site {
  id        String   @id @default(uuid())
  zoneId    String   @map("zone_id")
  name      String
  address   String
  latitude  Float
  longitude Float
  clientId  String?  @map("client_id")
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zone               Zone                @relation(fields: [zoneId], references: [id])
  routers            Router[]
  cameras            Camera[]
  incidents          Incident[]
  maintenanceWindows MaintenanceWindow[]

  @@map("sites")
}

model Router {
  id               String    @id @default(uuid())
  siteId           String    @map("site_id")
  serialNumber     String    @map("serial_number")
  imei             String
  simNumber        String    @map("sim_number")
  operator         String
  publicStaticIp   String    @map("public_static_ip")
  managementPort   Int       @map("management_port")
  model            String
  firmwareVersion  String    @map("firmware_version")
  lastSeenAt       DateTime? @map("last_seen_at")
  signalStrength   Int?      @map("signal_strength")
  connectionStatus String    @map("connection_status")
  dataApiAvailable Boolean   @default(false) @map("data_api_available")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  site         Site           @relation(fields: [siteId], references: [id])
  cameras      Camera[]
  simDataUsage SimDataUsage[]

  @@map("routers")
}

model Camera {
  id                      String             @id @default(uuid())
  // Placement + stream config are nullable: a DRAFT camera is registered with
  // identity only (see CameraProvisioning). These are populated when the camera
  // is configured, and are enforced as present at the CONFIGURED gate in
  // camera.service.ts — NOT by the database.
  siteId                  String?            @map("site_id")
  routerId                String?            @map("router_id")
  cameraCode              String             @unique @map("camera_code") // "CAM-042"
  name                    String
  brand                   String?
  model                   String?
  firmware                String?
  serialNumber            String?            @map("serial_number")
  mainRtspUrlEncrypted    String?            @map("main_rtsp_url_enc") // AES-256-GCM
  subRtspUrlEncrypted     String?            @map("sub_rtsp_url_enc") // AES-256-GCM
  mainRtspHash            String?            @unique @map("main_rtsp_hash") // normalized host+port+path (Postgres @unique permits many NULLs)
  subRtspHash             String?            @unique @map("sub_rtsp_hash") // normalized host+port+path (Postgres @unique permits many NULLs)
  rtspUsernameEncrypted   String?            @map("rtsp_username_enc")
  rtspPasswordEncrypted   String?            @map("rtsp_password_enc")
  onvifPort               Int?               @map("onvif_port")
  onvifCapabilities       Json?              @map("onvif_capabilities")
  playbackAdapter         PlaybackAdapter    @default(NONE) @map("playback_adapter")
  playbackVerified        Boolean            @default(false) @map("playback_verified")
  expectedCodec           String?            @map("expected_codec")
  expectedResolution      String?            @map("expected_resolution")
  expectedFps             Int?               @map("expected_fps")
  expectedBitrateKbps     Int?               @map("expected_bitrate_kbps")
  detectedSubCodec        String?            @map("detected_sub_codec") // ffprobe-measured sub-stream codec; drives Live Wall transcode (null = never probed → fail-safe transcode)
  provisioningState       CameraProvisioning @default(DRAFT) @map("provisioning_state")
  status                  CameraStatus       @default(UNKNOWN)
  healthScore             Int                @default(0) @map("health_score")
  diagnosis               Diagnosis?
  lastHealthyAt           DateTime?          @map("last_healthy_at")
  lastSnapshotAt          DateTime?          @map("last_snapshot_at")
  maintenanceMode         Boolean            @default(false) @map("maintenance_mode")
  latitude                Float?             // WGS-84 map position; null until placement is configured (was default 0)
  longitude               Float?
  snapshotIntervalMinutes Int                @default(60) @map("snapshot_interval_minutes")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  site                    Site?                     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  router                  Router?                   @relation(fields: [routerId], references: [id], onDelete: Restrict)
  referenceImages         ReferenceImage[]
  healthChecks            HealthCheck[]
  connectionQualityHourly ConnectionQualityHourly[]
  snapshots               Snapshot[]
  sdCardStatus            SdCardStatus?
  recordingSegments       RecordingSegment[]
  incidents               Incident[]
  maintenanceWindows      MaintenanceWindow[]
  maintenanceTasks        MaintenanceTask[]
  streamSessions          StreamSession[]
  clipExports             ClipExport[]

  @@index([siteId])
  @@index([status])
  @@index([provisioningState])
  @@map("cameras")
}

model ReferenceImage {
  id           String   @id @default(uuid())
  cameraId     String?  @map("camera_id")
  s3Key        String   @map("s3_key")
  approvedById String   @map("approved_by")
  approvedAt   DateTime @map("approved_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  camera     Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  approvedBy User   @relation(fields: [approvedById], references: [id], onDelete: Restrict)

  @@map("reference_images")
}

// ─────────────────────────────────────────────────────────────────────────────
// Monitoring
// ─────────────────────────────────────────────────────────────────────────────

model HealthCheck {
  id             String    @id @default(uuid())
  cameraId       String?   @map("camera_id")
  checkType      CheckType @map("check_type")
  startedAt      DateTime  @map("started_at")
  completedAt    DateTime? @map("completed_at")
  success        Boolean
  responseTimeMs Int?      @map("response_time_ms")
  errorCode      String?   @map("error_code")
  errorMessage   String?   @map("error_message")
  codec          String?
  resolution     String?
  fps            Int?
  bitrateKbps    Int?      @map("bitrate_kbps")
  framesReceived Int?      @map("frames_received")
  signalDbm      Int?      @map("signal_dbm")
  healthScore    Int?      @map("health_score")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  camera Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@index([cameraId, startedAt])
  @@map("health_checks")
}

model ConnectionQualityHourly {
  id              String   @id @default(uuid())
  cameraId        String?  @map("camera_id")
  hour            DateTime @db.Timestamptz(6)
  successRate     Float    @map("success_rate")
  medianLatencyMs Int      @map("median_latency_ms")
  jitterMs        Int      @map("jitter_ms")
  minSignalDbm    Int?     @map("min_signal_dbm")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  camera Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@unique([cameraId, hour])
  @@map("connection_quality_hourly")
}

model Snapshot {
  id               String       @id @default(uuid())
  cameraId         String?      @map("camera_id")
  capturedAt       DateTime     @map("captured_at")
  kind             SnapshotKind
  originalKey      String       @map("original_key")
  thumbnailKey     String       @map("thumbnail_key")
  brightnessScore  Float        @map("brightness_score")
  blurScore        Float        @map("blur_score")
  freezeScore      Float        @map("freeze_score")
  obstructionScore Float        @map("obstruction_score")
  sceneShiftScore  Float        @map("scene_shift_score")
  dustScore        Float        @map("dust_score")
  noiseScore       Float        @map("noise_score")
  colorCastScore   Float        @map("color_cast_score")
  analysisResult   Json         @map("analysis_result")
  analysisVersion  String       @map("analysis_version")
  stamped          Boolean      @default(true)
  stampText        String?      @map("stamp_text")
  latitude         Float?
  longitude        Float?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  camera                   Camera?           @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  incidentsAsPrevious      Incident[]        @relation("IncidentPreviousSnapshot")
  incidentsAsFault         Incident[]        @relation("IncidentFaultSnapshot")
  maintenanceTasksAsBefore MaintenanceTask[] @relation("MaintenanceTaskBeforeSnapshot")
  maintenanceTasksAsAfter  MaintenanceTask[] @relation("MaintenanceTaskAfterSnapshot")

  @@index([cameraId, capturedAt])
  @@map("snapshots")
}

model SdCardStatus {
  id               String    @id @default(uuid())
  cameraId         String?   @unique @map("camera_id")
  present          Boolean
  capacityGb       Float?    @map("capacity_gb")
  freeGb           Float?    @map("free_gb")
  recordingEnabled Boolean?  @map("recording_enabled")
  lastSegmentAt    DateTime? @map("last_segment_at")
  checkedAt        DateTime  @map("checked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  camera Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@map("sd_card_status")
}

model RecordingSegment {
  id           String         @id @default(uuid())
  cameraId     String?        @map("camera_id")
  source       String         @default("sd_card")
  track        RecordingTrack
  startAt      DateTime       @map("start_at")
  endAt        DateTime       @map("end_at")
  discoveredAt DateTime       @map("discovered_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  camera Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@index([cameraId, startAt])
  @@map("recording_segments")
}

model SimDataUsage {
  id          String   @id @default(uuid())
  routerId    String   @map("router_id")
  period      DateTime @db.Date
  bytesUsed   BigInt   @map("bytes_used")
  budgetBytes BigInt?  @map("budget_bytes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  router Router @relation(fields: [routerId], references: [id])

  @@unique([routerId, period])
  @@map("sim_data_usage")
}

// ─────────────────────────────────────────────────────────────────────────────
// Incidents & alerting
// ─────────────────────────────────────────────────────────────────────────────

model Incident {
  id                 String         @id @default(uuid())
  incidentNumber     String         @unique @map("incident_number") // "ANI-CAM-2026-000145"
  cameraId           String?        @map("camera_id")
  siteId             String         @map("site_id")
  zoneId             String         @map("zone_id") // zone snapshotted at creation
  type               String
  severity           Severity
  status             IncidentStatus
  diagnosis          Diagnosis?
  firstDetectedAt    DateTime       @map("first_detected_at")
  lastDetectedAt     DateTime       @map("last_detected_at")
  acknowledgedAt     DateTime?      @map("acknowledged_at")
  acknowledgedBy     String?        @map("acknowledged_by")
  assignedToId       String?        @map("assigned_to")
  resolvedAt         DateTime?      @map("resolved_at")
  recoveryVerifiedAt DateTime?      @map("recovery_verified_at")
  closedAt           DateTime?      @map("closed_at")
  rootCause          String?        @map("root_cause")
  resolutionNotes    String?        @map("resolution_notes")
  correctiveAction   String?        @map("corrective_action")
  spareParts         String?        @map("spare_parts")
  previousSnapshotId String?        @map("previous_snapshot_id")
  faultSnapshotId    String?        @map("fault_snapshot_id")
  downtimeSeconds    Int?           @map("downtime_seconds")
  slaImpact          Boolean        @default(false) @map("sla_impact")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  camera           Camera?               @relation(fields: [cameraId], references: [id])
  site             Site                  @relation(fields: [siteId], references: [id])
  zone             Zone                  @relation(fields: [zoneId], references: [id])
  assignedTo       User?                 @relation("IncidentAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  previousSnapshot Snapshot?             @relation("IncidentPreviousSnapshot", fields: [previousSnapshotId], references: [id])
  faultSnapshot    Snapshot?             @relation("IncidentFaultSnapshot", fields: [faultSnapshotId], references: [id])
  events           IncidentEvent[]
  notifications    Notification[]
  clipExports      ClipExport[]
  readReceipts     IncidentReadReceipt[]

  @@index([status])
  @@index([zoneId, firstDetectedAt])
  @@map("incidents")
}

model IncidentEvent {
  id         String   @id @default(uuid())
  incidentId String   @map("incident_id")
  actor      String?
  event      String
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at") // full timeline, append-only: no updated_at

  incident Incident @relation(fields: [incidentId], references: [id])

  @@map("incident_events")
}

model AlertRule {
  id                  String   @id @default(uuid())
  name                String
  condition           Json
  severity            Severity
  consecutiveFailures Int      @map("consecutive_failures")
  cooldownMinutes     Int      @map("cooldown_minutes")
  escalationPolicyId  String?  @map("escalation_policy_id")
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  escalationPolicy EscalationPolicy? @relation(fields: [escalationPolicyId], references: [id])

  @@map("alert_rules")
}

model EscalationPolicy {
  id        String   @id @default(uuid())
  name      String
  zoneId    String?  @map("zone_id") // null = default policy
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zone       Zone?            @relation(fields: [zoneId], references: [id])
  steps      EscalationStep[]
  alertRules AlertRule[]

  @@map("escalation_policies")
}

model EscalationStep {
  id             String    @id @default(uuid())
  policyId       String    @map("policy_id")
  afterMinutes   Int       @map("after_minutes")
  recipientLevel String    @map("recipient_level")
  channels       Channel[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  policy EscalationPolicy @relation(fields: [policyId], references: [id])

  @@map("escalation_steps")
}

model ZoneAlertRecipient {
  id              String   @id @default(uuid())
  zoneId          String   @map("zone_id")
  severity        Severity
  channel         Channel
  recipient       String
  escalationLevel Int      @map("escalation_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  zone Zone @relation(fields: [zoneId], references: [id])

  @@map("zone_alert_recipients")
}

model Notification {
  id                String             @id @default(uuid())
  incidentId        String             @map("incident_id")
  channel           Channel
  recipient         String
  templateName      String             @map("template_name")
  providerMessageId String?            @map("provider_message_id")
  status            NotificationStatus
  attemptCount      Int                @default(0) @map("attempt_count")
  sentAt            DateTime?          @map("sent_at")
  deliveredAt       DateTime?          @map("delivered_at")
  readAt            DateTime?          @map("read_at")
  failedAt          DateTime?          @map("failed_at")
  failureReason     String?            @map("failure_reason")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id])

  @@index([incidentId])
  @@map("notifications")
}

model MaintenanceWindow {
  id           String   @id @default(uuid())
  siteId       String?  @map("site_id")
  cameraId     String?  @map("camera_id")
  startAt      DateTime @map("start_at")
  endAt        DateTime @map("end_at")
  reason       String
  approvedById String   @map("approved_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  site       Site?   @relation(fields: [siteId], references: [id])
  camera     Camera? @relation(fields: [cameraId], references: [id])
  approvedBy User    @relation(fields: [approvedById], references: [id], onDelete: Restrict)

  @@map("maintenance_windows")
}

model MaintenanceTask {
  id               String     @id @default(uuid())
  cameraId         String?    @map("camera_id")
  type             TaskType
  source           TaskSource
  status           TaskStatus
  assignedToId     String?    @map("assigned_to")
  beforeSnapshotId String?    @map("before_snapshot_id")
  afterSnapshotId  String?    @map("after_snapshot_id")
  notes            String?
  completedAt      DateTime?  @map("completed_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  camera         Camera?   @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  assignedTo     User?     @relation("MaintenanceTaskAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)
  beforeSnapshot Snapshot? @relation("MaintenanceTaskBeforeSnapshot", fields: [beforeSnapshotId], references: [id])
  afterSnapshot  Snapshot? @relation("MaintenanceTaskAfterSnapshot", fields: [afterSnapshotId], references: [id])

  @@map("maintenance_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Streaming & playback
// ─────────────────────────────────────────────────────────────────────────────

model StreamSession {
  id              String     @id @default(uuid())
  cameraId        String?    @map("camera_id")
  userId          String     @map("user_id")
  kind            StreamKind
  mediamtxPath    String     @map("mediamtx_path")
  startedAt       DateTime   @map("started_at")
  lastHeartbeatAt DateTime   @map("last_heartbeat_at")
  endedAt         DateTime?  @map("ended_at")
  endReason       String?    @map("end_reason")
  clientIp        String     @map("client_ip")
  bytesEstimate   BigInt?    @map("bytes_estimate")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  camera Camera? @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([cameraId, endedAt])
  @@index([userId])
  @@map("stream_sessions")
}

model ClipExport {
  id            String     @id @default(uuid())
  cameraId      String?    @map("camera_id")
  requestedById String     @map("requested_by")
  startAt       DateTime   @map("start_at")
  endAt         DateTime   @map("end_at")
  status        ClipStatus
  s3Key         String?    @map("s3_key")
  sizeBytes     BigInt?    @map("size_bytes")
  error         String?
  incidentId    String?    @map("incident_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  camera      Camera?   @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  requestedBy User      @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  incident    Incident? @relation(fields: [incidentId], references: [id])

  @@map("clip_exports")
}

model SavedLayout {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  name      String
  layout    LayoutKind
  cameraIds Json       @map("camera_ids")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, name])
  @@map("saved_layouts")
}

enum BackupStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model UserPermission {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  permission PermissionType
  grantedBy  String         @map("granted_by")
  grantedAt  DateTime       @default(now()) @map("granted_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user    User @relation("UserPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  granter User @relation("UserPermissionGrantedBy", fields: [grantedBy], references: [id], onDelete: Restrict)

  @@unique([userId, permission])
  @@map("user_permissions")
}

model StoragePolicy {
  id             String    @id @default(uuid())
  scopeType      ScopeType @map("scope_type") // ZONE | SITE only (app-enforced)
  scopeId        String    @map("scope_id")
  storeClips     Boolean   @default(true) @map("store_clips")
  storeSnapshots Boolean   @default(true) @map("store_snapshots")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId])
  @@map("storage_policies")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // keys: retention_days, compression_quality, max_live_sessions_global, max_live_sessions_per_site
  @@map("system_settings")
}

model Backup {
  id          String       @id @default(uuid())
  requestedBy String       @map("requested_by")
  scopeType   ScopeType?   @map("scope_type")
  scopeId     String?      @map("scope_id")
  rangeStart  DateTime     @map("range_start")
  rangeEnd    DateTime     @map("range_end")
  status      BackupStatus @default(QUEUED)
  fileKey     String?      @map("file_key")
  sizeBytes   BigInt?      @map("size_bytes")
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  requester User @relation(fields: [requestedBy], references: [id], onDelete: Restrict)

  @@map("backups")
}

// Per-user read state for incident notifications (the in-app notification bell).
// Presence of a row = the user has read that incident's notification; absence =
// unread. Deliberately stores NO incident data — only the (user, incident) pair
// and when it was read — so it can never drift from the incident record. The
// @@unique makes marking-read idempotent (dup-proof) and also serves the
// per-user unread lookup (userId-prefixed). onDelete: Cascade follows the
// UserPermission.user precedent for a pure per-user pivot record: a receipt is
// meaningless once its user or incident is gone.
model IncidentReadReceipt {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  incidentId String   @map("incident_id")
  readAt     DateTime @default(now()) @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation("UserIncidentReadReceipts", fields: [userId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([userId, incidentId])
  @@index([incidentId])
  @@map("incident_read_receipts")
}
